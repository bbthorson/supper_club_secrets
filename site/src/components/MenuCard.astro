---
// The menu card — a book's table of contents plated as a restaurant menu
// (BRAND.md §1, §5). Four courses (the meals); each course lists its chapters
// as dotted-leader rows with Hot Sauce numerals. A "continue reading"
// affordance resumes at the reader's horizon (resolved client-side).
import Redaction from './Redaction.astro';

export interface CourseChapter {
  chapter: number;
  title: string;
  day?: string;
}
export interface Course {
  ordinal: string; // "First", "Second", …
  name: string; // the course/meal name
  tagline: string; // one evocative line
  /** Set true to render the tagline's trailing secret as a redaction. */
  secretTail?: string;
  chapters: CourseChapter[];
}
interface Props {
  eyebrow: string;
  title: string;
  subline: string;
  footnote: string;
  courses: Course[];
}
const { eyebrow, title, subline, footnote, courses } = Astro.props;
---

<article class="menu-card">
  <p class="mc-eyebrow scs-label">{eyebrow}</p>
  <h1 class="mc-title scs-poster">{title}</h1>
  <p class="mc-sub scs-romance">{subline}</p>

  <a class="mc-continue scs-label" href="/read/1" data-continue>Start reading</a>

  <div class="mc-courses">
    {
      courses.map((course) => (
        <section class="course">
          <div class="course-head">
            <span class="course-ordinal scs-label">{course.ordinal}</span>
            <h2 class="course-name scs-title">{course.name}</h2>
            <span class="scs-leader" aria-hidden="true" />
          </div>
          <p class="course-tagline scs-romance">
            {course.tagline}
            {course.secretTail && (
              <>
                {' '}
                <Redaction label="a course we can't print yet">{course.secretTail}</Redaction>
              </>
            )}
          </p>
          <ul class="course-chapters">
            {course.chapters.map((ch) => (
              <li class="chapter-row">
                <a class="chapter-link" href={`/read/${ch.chapter}`}>
                  <span class="chapter-no">{ch.chapter}</span>
                  <span class="chapter-title">{ch.title}</span>
                  <span class="scs-leader" aria-hidden="true" />
                  {ch.day && <span class="chapter-day scs-label">{ch.day}</span>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>

  <p class="mc-foot scs-romance">{footnote}</p>
</article>

<style>
  .menu-card {
    background: var(--scs-surface);
    border: 1px solid var(--scs-line);
    border-radius: var(--scs-radius);
    padding: clamp(1.75rem, 5vw, 3.25rem);
    box-shadow: 0 1px 0 var(--scs-line);
  }
  .mc-eyebrow {
    text-align: center;
    color: var(--scs-ornament);
    margin: 0 0 0.9rem;
  }
  .mc-title {
    text-align: center;
    font-size: var(--scs-text-poster);
    color: var(--scs-ink);
    margin: 0;
  }
  .mc-sub {
    text-align: center;
    font-size: var(--scs-text-romance);
    color: var(--scs-ink-muted);
    margin: 0.6rem 0 1.6rem;
  }
  .mc-continue {
    display: block;
    width: fit-content;
    margin: 0 auto 2.2rem;
    padding: 0.7em 1.4em;
    background: var(--scs-accent);
    color: var(--scs-linen);
    border-radius: var(--scs-radius);
    text-decoration: none;
    transition: filter 0.18s ease;
  }
  .mc-continue:hover {
    filter: brightness(1.06);
  }
  :global([data-theme='night']) .mc-continue {
    color: var(--scs-bottle);
  }

  .course {
    margin-top: 2rem;
  }
  .course:first-child {
    margin-top: 0;
  }
  .course-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  .course-ordinal {
    color: var(--scs-accent);
    white-space: nowrap;
  }
  .course-name {
    font-size: var(--scs-text-title);
    margin: 0;
    white-space: nowrap;
  }
  .course-tagline {
    color: var(--scs-ink-muted);
    margin: 0.15rem 0 0.9rem;
    font-size: 1.12rem;
  }

  .course-chapters {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .chapter-row + .chapter-row {
    margin-top: 0.15rem;
  }
  .chapter-link {
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
    text-decoration: none;
    color: var(--scs-ink);
    padding: 0.4rem 0.3rem;
    border-radius: var(--scs-radius);
    transition: background-color 0.15s ease;
  }
  .chapter-link:hover {
    background: var(--scs-linen-deep);
  }
  :global([data-theme='night']) .chapter-link:hover {
    background: rgba(241, 232, 212, 0.06);
  }
  .chapter-no {
    font-family: var(--scs-font-display);
    font-weight: 600;
    font-variation-settings: 'opsz' 40;
    color: var(--scs-accent);
    min-width: 1.6em;
    text-align: right;
    font-size: 1.05rem;
  }
  .chapter-title {
    font-family: var(--scs-font-body);
    font-size: 1.02rem;
  }
  .chapter-day {
    color: var(--scs-ink-muted);
    white-space: nowrap;
  }

  .mc-foot {
    text-align: center;
    color: var(--scs-ink-muted);
    margin: 2.4rem 0 0;
    padding-top: 1.4rem;
    border-top: var(--scs-leader);
    font-size: 1.05rem;
  }
</style>

<script>
  import { getHorizon, TOTAL_CHAPTERS } from '../lib/horizon';

  const link = document.querySelector<HTMLAnchorElement>('[data-continue]');
  if (link) {
    const horizon = getHorizon();
    if (horizon <= 0) {
      link.textContent = 'Start reading';
      link.href = '/read/1';
    } else if (horizon >= TOTAL_CHAPTERS) {
      link.textContent = 'Read from the top';
      link.href = '/read/1';
    } else {
      const next = horizon + 1;
      link.textContent = `Continue · Chapter ${next}`;
      link.href = `/read/${next}`;
    }
  }
</script>
