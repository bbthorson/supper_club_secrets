---
import { getCollection, render } from 'astro:content';
import ReadingRoom from '../../layouts/ReadingRoom.astro';

export async function getStaticPaths() {
  const chapters = (await getCollection('chapters')).sort(
    (a, b) => a.data.chapter - b.data.chapter,
  );
  return chapters.map((entry, i) => ({
    params: { chapter: String(entry.data.chapter) },
    props: {
      entry,
      prev: chapters[i - 1]?.data.chapter ?? null,
      next: chapters[i + 1]?.data.chapter ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const { chapter, title, meal, day, date } = entry.data;
---

<ReadingRoom
  chapter={chapter}
  title={title}
  meal={meal}
  day={day}
  date={date}
  prev={prev}
  next={next}
>
  <Content />
</ReadingRoom>
