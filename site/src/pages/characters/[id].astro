---
import Base from '../../layouts/Base.astro';
import FeedLens from '../../components/FeedLens.astro';
import { characterHubs, ANTAGONIST } from '../../lib/records';

export function getStaticPaths() {
  return characterHubs().map((hub) => ({
    params: { id: hub.slug },
    props: { hub },
  }));
}

const { hub } = Astro.props;
const { name, id, profile } = hub;
const club = profile ? profile.id !== ANTAGONIST : false;
const eyebrow = club ? 'A Regular' : 'In the Case';
const persona = profile?.personaPublic ?? profile?.oneLine ?? null;
---

<Base title={`${name} — Supper Club Secrets`} description={persona ?? name}>
  <article class="hub">
    <header class="hub-head">
      <p class="eyebrow scs-label">{eyebrow}</p>
      <h1 class="hub-name scs-poster">{name}</h1>
      {profile?.keyContradiction && <p class="hub-contra scs-romance">{profile.keyContradiction}</p>}
      {persona && <p class="hub-persona">{persona}</p>}
    </header>

    <FeedLens kind="character" entityId={id} bare threadLabel="Through the case" />
  </article>
</Base>

<style>
  .hub-head {
    text-align: center;
    max-width: 46ch;
    margin: 0 auto 2.4rem;
  }
  .eyebrow {
    color: var(--scs-ornament);
    margin: 0 0 0.7rem;
  }
  .hub-name {
    font-size: clamp(2.4rem, 7vw, 4rem);
    margin: 0;
  }
  .hub-contra {
    color: var(--scs-accent);
    font-size: var(--scs-text-romance);
    margin: 0.7rem 0 0;
  }
  .hub-persona {
    font-family: var(--scs-font-body);
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--scs-ink);
    margin: 1rem 0 0;
  }
</style>
