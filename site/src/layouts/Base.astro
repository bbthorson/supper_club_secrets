---
import '../../../protocol/brand/tokens.css';
import '../styles/base.css';
import { inlineHeadScript } from '../lib/horizon-inline';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  /** Hide the site chrome (header/footer) for full-bleed pages if ever needed. */
  bare?: boolean;
}
const { title, description = 'A cozy-crime supper club mystery, served in courses.', bare = false } =
  Astro.props;
---

<!doctype html>
<html lang="en" data-theme="day">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- pre-paint: apply stored theme + load progress, no flash -->
    <script is:inline set:html={inlineHeadScript} />
  </head>
  <body>
    {
      !bare && (
        <header class="site-header">
          <a class="wordmark" href="/" aria-label="Supper Club Secrets — home">
            <span class="wm-plain">Supper&nbsp;Club</span>
            <span class="wm-pop">Secrets</span>
          </a>
          <nav class="site-nav scs-label" aria-label="Primary">
            <a href="/">Menu</a>
            <a href="/timeline">Timeline</a>
            <a href="/characters">Cast</a>
            <a href="/shelf">Shelf</a>
          </nav>
          <ThemeToggle />
        </header>
      )
    }
    <main class="site-main">
      <slot />
    </main>
    {
      !bare && (
        <footer class="site-footer scs-label">
          <span>Williamsburg, Brooklyn · Thursdays</span>
          <span class="foot-note">Please inform your host of any secrets before dining.</span>
        </footer>
      )
    }
  </body>
</html>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.4rem;
    flex-wrap: wrap;
    max-width: 62rem;
    margin: 0 auto;
    padding: 1.4rem clamp(1rem, 4vw, 2.5rem);
    border-bottom: var(--scs-leader);
  }
  .site-nav {
    display: flex;
    gap: 1.1rem;
    margin-right: auto;
    margin-left: 0.4rem;
  }
  .site-nav a {
    color: var(--scs-ink-muted);
    text-decoration: none;
  }
  .site-nav a:hover {
    color: var(--scs-accent);
  }
  .wordmark {
    font-family: var(--scs-font-display);
    font-weight: 700;
    font-variation-settings: 'opsz' 40;
    font-size: 1.45rem;
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  .wm-plain {
    color: var(--scs-ink);
  }
  .wm-pop {
    color: var(--scs-accent);
    font-style: italic;
    margin-left: 0.12em;
  }
  .site-main {
    max-width: 62rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 5vw, 3.5rem) clamp(1rem, 4vw, 2.5rem);
  }
  .site-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 2rem;
    max-width: 62rem;
    margin: 2rem auto 0;
    padding: 1.4rem clamp(1rem, 4vw, 2.5rem) 2.6rem;
    border-top: var(--scs-leader);
    color: var(--scs-ink-muted);
  }
  .site-footer .foot-note {
    font-family: var(--scs-font-display);
    font-style: italic;
    font-weight: var(--scs-type-romance-weight);
    font-variation-settings: var(--scs-type-romance-variation);
    letter-spacing: 0;
    text-transform: none;
    font-size: 1rem;
    color: var(--scs-ink-muted);
  }
</style>
