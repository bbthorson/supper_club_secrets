{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "site.supperclub.place",
  "$comment": "Internal record schema. Placeholder NSID pending ARCHITECTURE.md §12.1. See ARCHITECTURE.md §6.3. `schedule` carries operating constraints (market days / hours) so a reader surface can flag open/closed on a story date.",
  "title": "place",
  "type": "object",
  "required": ["$type", "id", "name"],
  "additionalProperties": false,
  "properties": {
    "$type": {"const": "site.supperclub.place"},
    "id": {"type": "string", "pattern": "^place\\."},
    "name": {"type": "string"},
    "status": {"type": ["string", "null"]},
    "neighborhood": {"type": ["string", "null"]},
    "firstAppearance": {"type": ["string", "null"]},
    "schedule": {
      "type": ["object", "null"],
      "properties": {
        "days": {"type": "array", "items": {"type": "string"}},
        "hours": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "sourceFile": {"type": "string"}
  }
}
