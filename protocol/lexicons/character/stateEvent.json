{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "site.supperclub.character.stateEvent",
  "$comment": "Internal record schema. Placeholder NSID pending ARCHITECTURE.md §12.1. See ARCHITECTURE.md §6.2. createdAt is set to storyDate so records sort chronologically (§8).",
  "title": "character.stateEvent",
  "type": "object",
  "required": ["$type", "id", "subject", "storyDate", "register", "state", "chapterRef", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "$type": {"const": "site.supperclub.character.stateEvent"},
    "id": {"type": "string", "pattern": "^stateEvent\\."},
    "subject": {"type": "string", "pattern": "^char\\."},
    "storyDate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "storyDateEnd": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "register": {"type": "string", "enum": ["public", "private", "under-pressure"]},
    "registerExpr": {"type": "string", "$comment": "Full register expression as authored, e.g. a transition 'private -> deflating'."},
    "state": {"type": "string"},
    "chapterRef": {"type": "string"},
    "sceneRef": {"type": "string"},
    "createdAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "sourceFile": {"type": "string"}
  }
}
