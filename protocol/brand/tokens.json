{
  "$schema": "internal — mirrors tokens.css; BRAND.md is the human spec",
  "brand": "Supper Club Secrets",
  "direction": "The Menu",
  "locked": "2026-07-05",
  "color": {
    "day": {
      "linen": { "value": "#FBF8F1", "role": "page ground", "proportion": "~62%" },
      "linenDeep": { "value": "#F4EFE2", "role": "recessed panels" },
      "espresso": { "value": "#2A211C", "role": "text, redaction bars", "proportion": "~20%" },
      "brass": { "value": "#9C7C34", "role": "rules, leaders, numerals; never body-size text", "proportion": "~10%" },
      "hotSauce": { "value": "#C13A21", "role": "the single pop — accents, links, stickers", "proportion": "<=10%" },
      "hairline": { "value": "#E4DBC8", "role": "borders" },
      "card": { "value": "#FDFBF5", "role": "raised surfaces" }
    },
    "night": {
      "bottleGreen": { "value": "#10231C", "role": "ground" },
      "candle": { "value": "#E3AC44", "role": "accent, links, eyebrows" },
      "menuCream": { "value": "#F1E8D4", "role": "text" },
      "surface": { "value": "#163027", "role": "raised surfaces" }
    }
  },
  "typography": {
    "families": {
      "display": { "name": "Fraunces", "fallback": "Georgia, serif", "format": "variable: opsz 9-144, wght 100-900, SOFT 0-100, WONK 0-1, + italic", "license": "SIL OFL (Google Fonts)", "hosting": "self-hosted" },
      "body": { "name": "Literata", "fallback": "Georgia, serif", "license": "SIL OFL (Google Fonts)", "hosting": "self-hosted" },
      "label": { "name": "Archivo", "fallback": "Helvetica Neue, sans-serif", "license": "SIL OFL (Google Fonts)", "hosting": "self-hosted" }
    },
    "roles": {
      "poster": { "family": "display", "weight": 900, "variation": { "opsz": 144, "WONK": 1, "SOFT": 0 }, "use": "wordmark, covers, heroes, stamps" },
      "title": { "family": "display", "weight": 600, "variation": { "opsz": 90 }, "use": "book/chapter titles, section heads" },
      "romance": { "family": "display", "weight": 340, "style": "italic", "variation": { "opsz": 60, "WONK": 1 }, "use": "taglines, menu descriptions, pull-quotes" },
      "body": { "family": "body", "weight": 400, "sizePx": [17, 19], "use": "prose; Fraunces never sets a paragraph" },
      "label": { "family": "label", "weight": 600, "transform": "uppercase", "trackingEm": [0.14, 0.26], "use": "eyebrows, nav, metadata" }
    },
    "reading": { "measureCh": [65, 70], "sizePx": 19, "leading": 1.7 }
  },
  "ornament": {
    "leader": "2px dotted brass — menu rows, section heads, check lists",
    "radiusPx": 3,
    "asterisk": "marks a secret; always pays off in a footnote on the same surface"
  },
  "components": ["menu-card", "redaction", "sticker", "stamp", "dotted-leader"],
  "voice": {
    "register": "menu copy — warm, precise, joke in the footnote; tone capped at 7/10",
    "canonicalLines": [
      "*served family style",
      "Please inform your host of any secrets before dining.",
      "Now serving: Chapter …",
      "Case closed",
      "The check"
    ]
  }
}
